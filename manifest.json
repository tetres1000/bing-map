{
  "manifest_version": 3,
  "name": "workzone-detector",
  "version": "1.0",
  "description": "detects workzone",
  "permissions": [
    "activeTab",
    "scripting"
  ],
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "<all_urls>"
      ],
      "all_frames": true,
      "js": [
        "content.js"
      ]
    }
  ]
}